PORT=4000
APP_URL=https://api.archon.example.com
FRONTEND_URL=https://archon.example.com
SWAGGER_ENABLED=false
DATABASE_URL=mysql://archon:replace-me@db-host:3306/archon
JWT_ACCESS_SECRET=replace-with-long-production-access-secret
JWT_REFRESH_SECRET=replace-with-long-production-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
REFRESH_COOKIE_NAME=archon_refresh_token
# Optional override. Defaults to false outside production and true in production.
# REFRESH_COOKIE_SECURE=true
# Optional override. Defaults to 0 outside production and 1 in production.
# TRUST_PROXY_HOPS=1
# Mainline defaults now use no-email auth and link-based invites.
# Uncomment these only if you want to re-enable email verification and email invite delivery.
# EMAIL_VERIFICATION_MODE=required
# INVITE_DELIVERY_MODE=email
# Mainline no-email deployments can omit all MAIL_*, RESEND_*, and SMTP_* variables.
# Recommended if you explicitly re-enable email on platforms like Render free tier.
# MAIL_PROVIDER=resend
# MAIL_FROM=Archon <noreply@mail.example.com>
# RESEND_API_KEY=re_xxx
# Optional SMTP fallback if you later move off Render free or use local relay infra.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=replace-with-smtp-user
# SMTP_PASS=replace-with-smtp-password
# SMTP_FROM=noreply@example.com
# SMTP_CONNECTION_TIMEOUT_MS=10000
SEED_ENABLED=false
NODE_ENV=production
