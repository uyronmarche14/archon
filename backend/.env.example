PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
SWAGGER_ENABLED=true
DATABASE_URL=mysql://dowinn:dowinn@127.0.0.1:3308/dowinn
# If you change MYSQL_PORT in infra/.env, update the port here too.
JWT_ACCESS_SECRET=replace-with-long-local-access-secret
JWT_REFRESH_SECRET=replace-with-long-local-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
REFRESH_COOKIE_NAME=archon_refresh_token
# Optional override. Defaults to false outside production and true in production.
# REFRESH_COOKIE_SECURE=false
# Optional override. Defaults to 0 outside production and 1 in production.
# TRUST_PROXY_HOPS=0
# Optional hosted-environment auth modes. Default to bypass/link.
# EMAIL_VERIFICATION_MODE=bypass
# INVITE_DELIVERY_MODE=link
# No-email deployments can omit every MAIL_*, RESEND_*, and SMTP_* variable.
# Optional provider override if you intentionally re-enable email delivery.
# MAIL_PROVIDER=smtp
# Optional shared sender address used by Resend or SMTP.
# MAIL_FROM=Archon <noreply@example.com>
# Optional Resend settings if you later re-enable delivery.
# RESEND_API_KEY=re_xxx
# Optional SMTP settings if you later re-enable delivery.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=replace-with-smtp-user
# SMTP_PASS=replace-with-smtp-password
# SMTP_FROM=noreply@example.com
# SMTP_CONNECTION_TIMEOUT_MS=10000
SEED_ENABLED=false
NODE_ENV=development
