generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum AppRole {
  ADMIN
  MEMBER
}

enum ProjectMemberRole {
  OWNER
  MEMBER
}

enum ProjectStatusColor {
  SLATE
  BLUE
  AMBER
  GREEN
  RED
  PURPLE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskLogEventType {
  TASK_CREATED
  TASK_UPDATED
  STATUS_CHANGED
}

model User {
  id            String         @id @default(uuid()) @db.Char(36)
  name          String         @db.VarChar(120)
  email         String         @unique @db.VarChar(190)
  passwordHash  String         @map("password_hash") @db.VarChar(255)
  role          AppRole        @default(MEMBER)
  emailVerifiedAt DateTime?    @map("email_verified_at") @db.DateTime(3)
  refreshTokens RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  projectsOwned Project[]      @relation("ProjectOwner")
  memberships   ProjectMember[]
  tasksAssigned Task[]         @relation("TaskAssignee")
  tasksCreated  Task[]         @relation("TaskCreatedBy")
  tasksUpdated  Task[]         @relation("TaskUpdatedBy")
  taskLogs      TaskLog[]      @relation("TaskLogActor")
  taskComments  TaskComment[]  @relation("TaskCommentAuthor")
  taskAttachments TaskAttachment[] @relation("TaskAttachmentCreatedBy")
  sentProjectInvites ProjectInvite[] @relation("ProjectInviteSender")
  createdAt     DateTime       @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.DateTime(3)

  @@map("users")
}

model EmailVerificationToken {
  id         String    @id @default(uuid()) @db.Char(36)
  userId     String    @map("user_id") @db.Char(36)
  tokenHash  String    @unique @map("token_hash") @db.Char(64)
  expiresAt  DateTime  @map("expires_at") @db.DateTime(3)
  consumedAt DateTime? @map("consumed_at") @db.DateTime(3)
  redirectPath String? @map("redirect_path") @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Char(36)
  userId    String    @map("user_id") @db.Char(36)
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.DateTime(3)
  revokedAt DateTime? @map("revoked_at") @db.DateTime(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Project {
  id          String          @id @default(uuid()) @db.Char(36)
  name        String          @db.VarChar(120)
  description String?         @db.Text
  ownerId     String          @map("owner_id") @db.Char(36)
  owner       User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  members     ProjectMember[]
  statuses    ProjectStatus[]
  tasks       Task[]
  invites     ProjectInvite[]
  createdAt   DateTime        @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.DateTime(3)

  @@index([ownerId])
  @@map("projects")
}

model ProjectMember {
  id        String            @id @default(uuid()) @db.Char(36)
  projectId String            @map("project_id") @db.Char(36)
  userId    String            @map("user_id") @db.Char(36)
  role      ProjectMemberRole @default(MEMBER)
  createdAt DateTime          @default(now()) @map("created_at") @db.DateTime(3)
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ProjectStatus {
  id        String             @id @default(uuid()) @db.Char(36)
  projectId String             @map("project_id") @db.Char(36)
  name      String             @db.VarChar(80)
  position  Int
  isClosed  Boolean            @default(false) @map("is_closed")
  color     ProjectStatusColor @default(SLATE)
  createdAt DateTime           @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime           @updatedAt @map("updated_at") @db.DateTime(3)
  project   Project            @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tasks     Task[]

  @@unique([projectId, name])
  @@unique([projectId, position])
  @@index([projectId, position])
  @@map("project_statuses")
}

model Task {
  id                 String              @id @default(uuid()) @db.Char(36)
  projectId          String              @map("project_id") @db.Char(36)
  title              String              @db.VarChar(160)
  description        String?             @db.Text
  acceptanceCriteria String?             @map("acceptance_criteria") @db.Text
  notes              String?             @db.Text
  parentTaskId       String?             @map("parent_task_id") @db.Char(36)
  statusId           String              @map("status_id") @db.Char(36)
  position           Int?
  assigneeId         String?             @map("assignee_id") @db.Char(36)
  dueDate            DateTime?           @map("due_date") @db.Date
  createdById        String              @map("created_by") @db.Char(36)
  updatedById        String?             @map("updated_by") @db.Char(36)
  createdAt          DateTime            @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.DateTime(3)
  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  parentTask         Task?               @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  subtasks           Task[]              @relation("TaskSubtasks")
  status             ProjectStatus       @relation(fields: [statusId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assignee           User?               @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdBy          User                @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  updatedBy          User?               @relation("TaskUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  taskLogs           TaskLog[]
  links              TaskLink[]
  checklistItems     TaskChecklistItem[]
  comments           TaskComment[]
  attachments        TaskAttachment[]

  @@index([projectId])
  @@index([statusId])
  @@index([parentTaskId])
  @@index([projectId, statusId])
  @@map("tasks")
}

model TaskLog {
  id        String           @id @default(uuid()) @db.Char(36)
  taskId    String           @map("task_id") @db.Char(36)
  actorId   String           @map("actor_id") @db.Char(36)
  eventType TaskLogEventType @map("event_type")
  fieldName String?          @map("field_name") @db.VarChar(80)
  oldValue  Json?            @map("old_value")
  newValue  Json?            @map("new_value")
  summary   String           @db.VarChar(255)
  createdAt DateTime         @default(now()) @map("created_at") @db.DateTime(3)
  task      Task             @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  actor     User             @relation("TaskLogActor", fields: [actorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([taskId, createdAt])
  @@map("task_logs")
}

model TaskLink {
  id        String   @id @default(uuid()) @db.Char(36)
  taskId     String   @map("task_id") @db.Char(36)
  label      String   @db.VarChar(160)
  url        String   @db.VarChar(2048)
  position   Int
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([taskId, position])
  @@map("task_links")
}

model TaskChecklistItem {
  id          String   @id @default(uuid()) @db.Char(36)
  taskId      String   @map("task_id") @db.Char(36)
  label       String   @db.VarChar(255)
  isCompleted Boolean  @default(false) @map("is_completed")
  position    Int
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([taskId, position])
  @@map("task_checklist_items")
}

model TaskComment {
  id        String   @id @default(uuid()) @db.Char(36)
  taskId    String   @map("task_id") @db.Char(36)
  authorId  String   @map("author_id") @db.Char(36)
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  author    User     @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([taskId, createdAt])
  @@index([authorId])
  @@map("task_comments")
}

model TaskAttachment {
  id          String   @id @default(uuid()) @db.Char(36)
  taskId      String   @map("task_id") @db.Char(36)
  label       String?  @db.VarChar(160)
  fileName    String   @map("file_name") @db.VarChar(255)
  url         String   @db.VarChar(2048)
  mimeType    String?  @map("mime_type") @db.VarChar(120)
  sizeBytes   Int?     @map("size_bytes")
  createdById String   @map("created_by_id") @db.Char(36)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdBy   User     @relation("TaskAttachmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([taskId, createdAt])
  @@index([createdById])
  @@map("task_attachments")
}

model ProjectInvite {
  id         String            @id @default(uuid()) @db.Char(36)
  projectId  String            @map("project_id") @db.Char(36)
  invitedById String           @map("invited_by_id") @db.Char(36)
  email      String            @db.VarChar(190)
  role       ProjectMemberRole @default(MEMBER)
  tokenHash  String            @unique @map("token_hash") @db.Char(64)
  expiresAt  DateTime          @map("expires_at") @db.DateTime(3)
  acceptedAt DateTime?         @map("accepted_at") @db.DateTime(3)
  createdAt  DateTime          @default(now()) @map("created_at") @db.DateTime(3)
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  invitedBy  User              @relation("ProjectInviteSender", fields: [invitedById], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([projectId])
  @@index([email])
  @@index([projectId, email, acceptedAt, expiresAt])
  @@map("project_invites")
}
