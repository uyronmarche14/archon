    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup Owner",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runId = `run_${Date.now()}_${Math.floor(Math.random() * 100000)}`;",
                  "pm.collectionVariables.set('runId', runId);",
                  "pm.collectionVariables.set('ownerName', 'Owner User');",
                  "pm.collectionVariables.set('ownerEmail', `${runId}.owner@example.com`);",
                  "pm.collectionVariables.set('ownerPassword', 'StrongPass1');",
                  "pm.collectionVariables.set('projectName', `Launch ${runId}`);",
                  "pm.collectionVariables.set('projectDescription', 'Track launch tasks');",
                  "pm.collectionVariables.set('updatedProjectName', `Updated ${runId}`);",
                  "pm.collectionVariables.set('taskTitle', `Checklist ${runId}`);",
                  "pm.collectionVariables.set('taskDescription', 'Prepare go-live readiness checklist');",
                  "pm.collectionVariables.set('updatedTaskTitle', `Updated checklist ${runId}`);",
                  "pm.collectionVariables.unset('ownerAccessToken');",
                  "pm.collectionVariables.unset('outsiderAccessToken');",
                  "pm.collectionVariables.unset('projectId');",
                  "pm.collectionVariables.unset('taskId');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('signup owner returns 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('signup owner returns normalized auth envelope', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.error).to.eql(null);",
                  "  pm.expect(body.data.user.email).to.eql(pm.collectionVariables.get('ownerEmail'));",
                  "  pm.expect(body.data.user.name).to.eql(pm.collectionVariables.get('ownerName'));",
                  "  pm.expect(body.data.user.role).to.eql('MEMBER');",
                  "  pm.expect(body.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.meta.requestId).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.collectionVariables.set('ownerAccessToken', body.data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{ownerName}}\",\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            }
          }
        },
