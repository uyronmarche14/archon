              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('get project detail returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('get project detail returns board-ready shape', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.data.id).to.eql(pm.collectionVariables.get('projectId'));",
                  "  pm.expect(body.data.taskGroups).to.have.property('TODO');",
                  "  pm.expect(body.data.taskGroups).to.have.property('IN_PROGRESS');",
                  "  pm.expect(body.data.taskGroups).to.have.property('DONE');",
                  "  pm.expect(body.data.taskGroups.TODO).to.be.an('array');",
                  "  pm.expect(body.data.members).to.be.an('array');",
                  "  const ownerMember = body.data.members.find((member) => member.name === pm.collectionVariables.get('ownerName'));",
                  "  pm.expect(ownerMember).to.exist;",
                  "  pm.expect(ownerMember.role).to.eql('OWNER');",
                  "});"
                ]
              }
            }
