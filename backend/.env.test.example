PORT=4001
APP_URL=http://localhost:4001
FRONTEND_URL=http://localhost:3000
SWAGGER_ENABLED=true
DATABASE_URL=mysql://dowinn:dowinn@localhost:3307/dowinn_test
JWT_ACCESS_SECRET=test-access-secret-12345
JWT_REFRESH_SECRET=test-refresh-secret-12345
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
REFRESH_COOKIE_NAME=archon_refresh_token_test
# Optional override. Defaults to false outside production and true in production.
# REFRESH_COOKIE_SECURE=false
# Optional override. Defaults to 0 outside production and 1 in production.
# TRUST_PROXY_HOPS=0
# Optional hosted-environment auth modes. Runtime defaults now use bypass/link.
# EMAIL_VERIFICATION_MODE=bypass
# INVITE_DELIVERY_MODE=link
# No-email test runs can omit every MAIL_*, RESEND_*, and SMTP_* variable.
# Optional provider override. Tests default to smtp unless you specifically cover Resend.
# MAIL_PROVIDER=smtp
# MAIL_FROM=Archon Test <noreply@example.test>
# RESEND_API_KEY=re_test
# Optional SMTP settings only for test runs that explicitly exercise dormant mail delivery.
# SMTP_HOST=smtp.example.test
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=test-smtp-user
# SMTP_PASS=test-smtp-password
# SMTP_FROM=noreply@example.test
# SMTP_CONNECTION_TIMEOUT_MS=3000
SEED_ENABLED=false
NODE_ENV=test
